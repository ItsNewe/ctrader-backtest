[nix]
channel = "stable-25_05"
packages = ["unzip"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Backtest"

[[workflows.workflow]]
name = "Run Backtest"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "g++ -Ictrader-backtest-main/include ctrader-backtest-main/src/main.cpp ctrader-backtest-main/src/engine/backtest_engine.cpp -o backtest_app && ./backtest_app"
